DJANGO_DEBUG=1
DJANGO_SECRET_KEY=change-me
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Local dev: Docker Postgres (see infra/docker-compose.yml)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=afapi_dev
DB_USER=afapi
DB_PASSWORD=afapi
DB_HOST=127.0.0.1
DB_PORT=5432

# Production (Render + Supabase): set DATABASE_URL in Render dashboard only.
# Supabase → Project Settings → Database → URI, Session pooler (port 5432).
# Append ?sslmode=require if not already in the string. Example shape:
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres?sslmode=require
#
# Do not commit real credentials. Cron jobs inherit DATABASE_URL from the web service.

# Production e-mail on Render (SMTP ports blocked — use Brevo HTTP API):
# BREVO_API_KEY=your-v3-api-key-from-brevo-dashboard
#
# Alternative: classic SMTP (works on hosts that allow ports 587/465):
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=1
# EMAIL_USE_SSL=0
# EMAIL_TIMEOUT=10
# DEFAULT_FROM_EMAIL=Jobbsöket <no-reply@example.com>
# Public site origin (no trailing path). E-mail links use /app/ automatically.
# FRONTEND_URL=https://jobbsoket.se

# Public contact for the privacy policy and /.well-known/security.txt:
# CONTACT_EMAIL=you@example.com

# Bootstrap (optional — production). Use a unique username, not "admin".
# DJANGO_SUPERUSER_USERNAME=ansokt-ops
# DJANGO_SUPERUSER_EMAIL=you@example.com
# DJANGO_SUPERUSER_PASSWORD=

# Optional error monitoring
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# SENTRY_DSN_FRONTEND=
# SENTRY_ENVIRONMENT=development
# SENTRY_TRACES_SAMPLE_RATE=0.1
