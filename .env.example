DJANGO_DEBUG=1
DJANGO_SECRET_KEY=change-me
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

DB_ENGINE=django.db.backends.postgresql
DB_NAME=afapi_dev
DB_USER=afapi
DB_PASSWORD=afapi
DB_HOST=127.0.0.1
DB_PORT=5432

# Production e-mail on Render (SMTP ports blocked — use Brevo HTTP API):
# BREVO_API_KEY=your-v3-api-key-from-brevo-dashboard
#
# Alternative: classic SMTP (works on hosts that allow ports 587/465):
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=1
# EMAIL_USE_SSL=0
# EMAIL_TIMEOUT=10
# DEFAULT_FROM_EMAIL=Ansökt <no-reply@example.com>
# FRONTEND_URL=https://your-app.onrender.com

# Optional error monitoring
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# SENTRY_DSN_FRONTEND=
# SENTRY_ENVIRONMENT=development
# SENTRY_TRACES_SAMPLE_RATE=0.1
