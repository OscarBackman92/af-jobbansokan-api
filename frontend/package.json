{
  "name": "af-jobbansokan-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "openapi:export": "node scripts/export-openapi.mjs",
    "openapi:types": "openapi-typescript openapi.json -o src/types/api.generated.ts",
    "openapi": "npm run openapi:export && npm run openapi:types"
  },
  "dependencies": {
    "@sentry/react": "^10.62.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "openapi-typescript": "~7.6.0",
    "puppeteer-core": "^25.1.0",
    "typescript": "~5.9.0",
    "vite": "^7.1.0",
    "vitest": "^4.1.9"
  }
}
